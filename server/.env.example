# ── Kinetic Ledger API environment ───────────────────────────────────────────

# PostgreSQL connection string.
# For Supabase, use the CONNECTION POOLER url (port 6543) here for the running app:
#   postgresql://postgres.<ref>:<password>@<host>:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres?schema=public"

# Secret used to sign JWTs. Use a long, random string in production.
JWT_SECRET="replace-with-a-long-random-secret"

# Port the API listens on.
PORT=4000

# Allowed CORS origin (the frontend dev server / deployed site).
FRONTEND_URL="http://localhost:3000"
